<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/jericho"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_f3">

    <Button
        android:id="@+id/btnCompanionList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lista"
        android:textColor="#CC9900"
        android:textSize="25sp"
        android:fontFamily="@font/overseer_italic"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>


    <TextView
        android:id="@+id/txtJericho"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jericho"
        android:textColor="#50AF4F"
        android:textSize="50sp"
        android:fontFamily="@font/overseer_italic"
        app:layout_constraintTop_toBottomOf="@id/btnCompanionList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textAlignment="center"
        android:layout_marginTop="20dp"/>

    <ImageView
        android:id="@+id/imgJericho"
        android:layout_width="140dp"
        android:layout_height="241dp"
        android:layout_marginTop="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/jericho"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtJericho" />


    <TextView
        android:id="@+id/txtJerichoInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/overseer_italic"
        android:text="Jericho es un habitante de Megatón, ex saqueador y al que es posible contratarle como compañero. Para ello hay que tener un karma malo y pagarle una cantidad de 1000 chapas. Utiliza un rifle de asalto como arma de distancia. "
        android:textAlignment="center"
        android:textColor="#50AF4F"
        android:textSize="25sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.492"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgJericho" />

</androidx.constraintlayout.widget.ConstraintLayout>
