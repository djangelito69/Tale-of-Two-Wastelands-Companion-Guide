<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ede"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_fnv">

    <Button
        android:id="@+id/btnCompanionList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lista"
        android:textColor="#CC9900"
        android:textSize="25sp"
        android:fontFamily="@font/overseer_italic"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>


    <TextView
        android:id="@+id/txtEDE"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ED-E"
        android:textColor="#CC9900"
        android:textSize="50sp"
        android:fontFamily="@font/overseer_italic"
        app:layout_constraintTop_toBottomOf="@id/btnCompanionList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textAlignment="center"
        android:layout_marginTop="20dp"/>

    <ImageView
        android:id="@+id/imgEDE"
        android:layout_width="140dp"
        android:layout_height="241dp"
        android:layout_marginTop="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ede"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtEDE" />


    <TextView
        android:id="@+id/txtEDEInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/overseer_italic"
        android:text="El sujeto E de ojobot Duraframe, también conocido como ED-E, es un ojobot Duraframe y posible compañero del Mensajero en el año 2281. Se encuentra estropeado y está en la residencia Nash en Primm."
        android:textAlignment="center"
        android:textColor="#CC9900"
        android:textSize="25sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.492"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgEDE" />

</androidx.constraintlayout.widget.ConstraintLayout>